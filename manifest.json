{
  "manifest_version": 3,
  "name": "Clean LinkedIn",
  "version": "1.0.0",
  "description": "Remove posts patrocinados, vagas recomendadas e outros elementos de ruído do feed do LinkedIn",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clean LinkedIn"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
